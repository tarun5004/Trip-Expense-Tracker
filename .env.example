# ==========================================
# SERVER CONFIGURATION (.env inside /server)
# ==========================================

# Port the Express server listens on
# Example: 5000
PORT=5000

# Node running environment (development, staging, production)
# Example: development
NODE_ENV=development

# Full connection string for PostgreSQL (Raw pg driver uses this natively)
# Example: postgres://user:pass@localhost:5432/splitsmart_db
DATABASE_URL=postgres://postgres:password123@localhost:5432/splitsmart_dev

# Connection string for Redis cache & socket pub/sub
# Example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Cryptographic key used to sign Access Tokens (JWT)
# REQUIRED. Example: a_very_long_random_string
JWT_ACCESS_SECRET=your_super_secret_access_key

# Cryptographic key used to sign Refresh Tokens via httpOnly cookie
# REQUIRED. Example: another_very_long_random_string
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# Access Token Time-to-Live (Mins/Hours)
# Config: 15m is recommended for high security financial apps
JWT_ACCESS_EXPIRES=15m

# Refresh Token Time-to-Live (Days)
# Config: 7d allows users to stay logged in moderately securely
JWT_REFRESH_EXPIRES=7d

# Cross-Origin allowed domain (The Frontend Client URL)
# Example: http://localhost:5173 (Vite default)
CORS_ORIGIN=http://localhost:5173


# ==========================================
# CLIENT CONFIGURATION (.env inside /client)
# Note: Vite requires VITE_ prefix. Create-React-App requires REACT_APP_
# ==========================================

# Base URL pointing to the Backend API
# Example: http://localhost:5000/api/v1
VITE_API_URL=http://localhost:5000/api/v1
REACT_APP_API_URL=http://localhost:5000/api/v1

# URL pointing to the NodeJS root for Socket.io attachment
# Example: http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# Client Environment
REACT_APP_ENV=development
